# Required: model name
PIXIA_MODEL=deepseek-v4-flash

# Required: provider base URL
PIXIA_BASE_URL=https://api.deepseek.com

# Required: which API key variable to read
# Example: DEEPSEEK_API_KEY / OPENAI_API_KEY / OPENROUTER_API_KEY
PIXIA_API_KEY_ENV=DEEPSEEK_API_KEY

# Optional: api mode. Supported: completions | response | anthropic
PIXIA_API_MODE=completions

# Optional: system prompt passed via modelOptions.systemPrompt in agent.execute
PIXIA_SYSTEM_PROMPT=You are a helpful assistant.

# Optional: request timeout (ms)
PIXIA_MODEL_TIMEOUT_MS=120000

# Optional: max iterations in agent loop
PIXIA_MAX_ITERATIONS=8

# Optional: retries for model requests
PIXIA_MAX_MODEL_RETRIES=1

# Optional: observability switch
PIXIA_OTEL_ENABLED=false

# Optional: grpc | http | none
PIXIA_OTEL_TRANSPORT=none

# Required when transport is grpc/http
# grpc example: localhost:4317
# http example: http://localhost:4318
PIXIA_OTEL_ENDPOINT=

# Optional: telemetry for traces and metrics
PIXIA_OTEL_ENABLE_TELEMETRY=false

# Optional: service identity
PIXIA_OTEL_SERVICE_NAME=pixiagent-tui-demo
PIXIA_OTEL_SERVICE_VERSION=0.1.0

# Optional: logging sinks
# Keep false for TUI. Console logs can break terminal rendering.
PIXIA_OTEL_OUTPUT_TO_CONSOLE=false
PIXIA_OTEL_OUTPUT_TO_OTEL=false

# The actual key variable pointed by PIXIA_API_KEY_ENV
DEEPSEEK_API_KEY=
