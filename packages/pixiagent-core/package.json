{
  "name": "@pixiagent/core",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint . --ext .ts",
    "test": "bun run test:unit",
    "test:unit": "vitest run --config ../../vitest.config.ts",
    "test:browser-unit": "vitest run --config ../../vitest.browser-unit.config.ts",
    "test:integration": "vitest run --config ../../vitest.integration.config.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    },
    "./agent-manager": {
      "types": "./dist/agent-manager.d.ts",
      "default": "./dist/agent-manager.js"
    },
    "./message": {
      "types": "./dist/message.d.ts",
      "default": "./dist/message.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "default": "./dist/model.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./tool": {
      "types": "./dist/tool.d.ts",
      "default": "./dist/tool.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./errors/*": {
      "types": "./dist/errors/*.d.ts",
      "default": "./dist/errors/*.js"
    },
    "./observation": {
      "types": "./dist/observation/index.d.ts",
      "browser": "./dist/observation/browser.js",
      "default": "./dist/observation/index.js"
    },
    "./transports": {
      "types": "./dist/transports/index.d.ts",
      "default": "./dist/transports/index.js"
    },
    "./transports/*": {
      "types": "./dist/transports/*.d.ts",
      "default": "./dist/transports/*.js"
    }
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.1",
    "@anthropic-ai/sdk": "^0.91.1",
    "@opentelemetry/api": "^1.9.1",
    "fast-xml-parser": "^5.7.3",
    "nanoid": "^5.1.11",
    "openai": "^6.35.0",
    "p-queue": "^9.2.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@opentelemetry/api-logs": ">=0.210.0",
    "@opentelemetry/exporter-logs-otlp-http": ">=0.210.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": ">=0.210.0",
    "@opentelemetry/exporter-metrics-otlp-http": ">=0.210.0",
    "@opentelemetry/exporter-trace-otlp-grpc": ">=0.210.0",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.210.0",
    "@opentelemetry/resources": ">=1.25.0",
    "@opentelemetry/sdk-logs": ">=0.210.0",
    "@opentelemetry/sdk-metrics": ">=1.25.0",
    "@opentelemetry/sdk-node": ">=0.210.0",
    "@opentelemetry/sdk-trace-base": ">=1.25.0",
    "@opentelemetry/sdk-trace-web": ">=1.25.0",
    "@opentelemetry/semantic-conventions": ">=1.27.0",
    "pino-opentelemetry-transport": ">=3.0.0",
    "pino-pretty": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/exporter-metrics-otlp-grpc": {
      "optional": true
    },
    "@opentelemetry/exporter-metrics-otlp-http": {
