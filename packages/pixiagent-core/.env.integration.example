# Copy this file to .env.integration and fill in values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-mini
RUN_LIVE_INTEGRATION_TESTS=false

# OTel / observation — set OTEL_ENABLED=true to forward logs/traces/metrics
# to an OTel Collector running locally (e.g. via Docker Compose).
OTEL_ENABLED=false
OTEL_TRANSPORT=grpc
OTEL_GRPC_ENDPOINT=localhost:9937
OTEL_HTTP_ENDPOINT=http://localhost:9938
OTEL_SERVICE_NAME=pixiagent-integration-test