{
  "name": "pixiagent",
  "private": true,
  "version": "0.1.0",
  "description": "A TypeScript Bun monorepo for the Pixi agent system.",
  "packageManager": "bun@1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "bun install",
    "build": "bun workspaces run build",
    "lint": "bun workspaces run lint",
    "test": "bun workspaces run test:unit",
    "test:unit": "bun workspaces run test:unit",
    "test:integration": "bun workspaces run test:integration",
    "test:all": "bun workspaces run test:unit && bun workspaces run test:integration",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
